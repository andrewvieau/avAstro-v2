---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FeaturedPost from '../../components/FeaturedPost.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featuredPost = posts.find((p) => p.data.featured);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="Writing on Sitecore, web development, and learning in public." />
		<style>
			h1 {
				margin-bottom: 1.5em;
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				border-top: 1px solid rgb(var(--gray-light));
			}
			.post-list li:last-child {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-list a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1.5em;
				padding: 1em 0;
				text-decoration: none;
				color: rgb(var(--black));
			}
			.post-title {
				font-size: 1em;
				font-weight: 700;
				flex: 1;
				transition: color 0.15s;
			}
			.post-list a:hover .post-title {
				color: var(--accent);
			}
			.post-date {
				font-size: 0.82em;
				color: rgb(var(--gray));
				white-space: nowrap;
				flex-shrink: 0;
			}
			.post-description {
				font-size: 0.9em;
				color: rgb(var(--gray));
				margin: 0.1em 0 0;
				line-height: 1.4;
			}
			.post-text {
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 0.2em;
			}
			@media (max-width: 480px) {
				.post-list a {
					flex-direction: column;
					gap: 0.25em;
				}
				.post-date {
					font-size: 0.8em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			{featuredPost && <FeaturedPost post={featuredPost} />}
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<div class="post-text">
									<span class="post-title">{post.data.title}</span>
									<span class="post-description">{post.data.description}</span>
								</div>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
